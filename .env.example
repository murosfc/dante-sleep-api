# Firebase Admin SDK - create a service account in Firebase Console:
# Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=dante-sleep
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dante-sleep.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# NVIDIA API key (same as used in the Flutter app)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: your Alexa Skill ID for request validation
# Format: amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ALEXA_SKILL_ID=
